{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Luminaire",
  "version": "1.0.0",
  "identifier": "com.luminaire.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Luminaire",
        "width": 320,
        "height": 480,
        "resizable": false,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Control Elgato Key Light Neo",
    "longDescription": "Control Elgato Key Light Neo via its HTTP API"
  }
}
